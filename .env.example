# ──────────────────────────────────────────────
# Honeygen – environment configuration
# Copy this file to .env and edit the values.
# Docker Compose loads .env automatically.
# ──────────────────────────────────────────────

# ── Application ──────────────────────────────
# APP_ENV is required. Use one of: development, staging, production.
APP_ENV=development
APP_VERSION=dev

# ── Service ports (host-side, used in docker-compose.yml ports mapping) ──
API_PORT=8080
ADMIN_WEB_PORT=4173
DECOY_WEB_PORT=8081
DEPLOYMENT_PORTS=9000-9020
FTP_PASSIVE_PORTS=9011-9020

# ── Internal listen addresses (inside containers) ──
API_HTTP_ADDR=:8080
DECOY_WEB_HTTP_ADDR=:8081

# ── Paths (inside containers — rarely need changing) ──
CONFIG_PATH=/app/config/config.json
SQLITE_PATH=/app/storage/sqlite/honeygen.db
STORAGE_ROOT=/app/storage
GENERATED_ASSETS_DIR=/app/storage/generated

# ── Internal service communication ──
# Base URL the decoy-web container uses to reach the API container.
INTERNAL_API_BASE_URL=http://api:8080
# Shared secret between decoy-web and the API for event ingestion.
# Generate a random 32+ character token for production use.
# Example: INTERNAL_EVENT_INGEST_TOKEN=2f9b7d9b1e4c0fbe6d709667f5c2a4b8
INTERNAL_EVENT_INGEST_TOKEN=replace-with-long-random-internal-event-token
# Admin UI password checked by /api/auth/login.
# Example: ADMIN_PASSWORD=use-a-long-random-passphrase-here
ADMIN_PASSWORD=replace-with-long-random-admin-password
# Encrypts the saved provider API key before it is written to SQLite.
# Example: PROVIDER_CONFIG_ENCRYPTION_KEY=1b2c3d4e5f60718293a4b5c6d7e8f901
PROVIDER_CONFIG_ENCRYPTION_KEY=replace-with-long-random-encryption-key
# Public host/IP advertised by FTP PASV responses when running behind Docker NAT.
FTP_PUBLIC_HOST=127.0.0.1

# ── Frontend (build-time only) ──
# Leave empty when using the admin-web NGINX proxy (default).
# Set to http://localhost:8080 for direct browser-to-API development.
VITE_API_BASE_URL=

# ── LLM Provider ──
# OpenAI-compatible endpoint. For a local llama.cpp server, use:
#   LLM_BASE_URL=http://host.docker.internal:8033/v1
# For OpenAI itself:
#   LLM_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-with-provider-api-key
LLM_MODEL=gpt-4o-mini

# ── Upload limits ─────────────────────────────
# Maximum size for custom file uploads to completed jobs (bytes).
# Default: 26214400 (25 MB). Absolute hard cap: 104857600 (100 MB).
# MAX_UPLOAD_SIZE_BYTES=26214400

# ── MaxMind GeoIP (optional) ──────────────────
# Sign up at https://www.maxmind.com/ for a free GeoLite2 account.
# When set, the API will download the GeoLite2-City database and enrich
# ingested events with country, city, ASN, and organisation data.
# Leave blank to disable GeoIP enrichment.
MM_ACCOUNT_ID=
MM_LICENSE_KEY=
# Path where the GeoLite2-City.mmdb file is stored inside the container.
# Defaults to <STORAGE_ROOT>/geoip/GeoLite2-City.mmdb when not set.
# MM_DB_PATH=
