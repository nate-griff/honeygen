# ──────────────────────────────────────────────
# Honeygen – environment configuration
# Copy this file to .env and edit the values.
# Docker Compose loads .env automatically.
# ──────────────────────────────────────────────

# ── Application ──────────────────────────────
APP_ENV=development
APP_VERSION=dev

# ── Service ports (host-side, used in docker-compose.yml ports mapping) ──
API_PORT=8080
ADMIN_WEB_PORT=4173
DECOY_WEB_PORT=8081

# ── Internal listen addresses (inside containers) ──
API_HTTP_ADDR=:8080
DECOY_WEB_HTTP_ADDR=:8081

# ── Paths (inside containers — rarely need changing) ──
CONFIG_PATH=/app/config/config.json
SQLITE_PATH=/app/storage/sqlite/honeygen.db
STORAGE_ROOT=/app/storage
GENERATED_ASSETS_DIR=/app/storage/generated

# ── Internal service communication ──
# Base URL the decoy-web container uses to reach the API container.
INTERNAL_API_BASE_URL=http://api:8080
# Shared secret between decoy-web and the API for event ingestion.
# Generate a random token for production use.
INTERNAL_EVENT_INGEST_TOKEN=replace-with-internal-event-token

# ── Frontend (build-time only) ──
# Leave empty when using the admin-web NGINX proxy (default).
# Set to http://localhost:8080 for direct browser-to-API development.
VITE_API_BASE_URL=

# ── LLM Provider ──
# OpenAI-compatible endpoint. For a local llama.cpp server, use:
#   LLM_BASE_URL=http://host.docker.internal:8033/v1
# For OpenAI itself:
#   LLM_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-with-provider-api-key
LLM_MODEL=gpt-4o-mini
